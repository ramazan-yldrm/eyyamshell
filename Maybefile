NAME        = minishell
CC          = cc
# 42 kuralları için -Wall -Wextra -Werror eklemeyi unutma!
CFLAGS      = -Wall -Wextra -Werror -Iinc -Ilib 
LIBS        = -Llib -lft -lreadline
LIBFT       = lib/libft.a

# Klasör Tanımlamaları
SRC_DIR     = src/
OBJ_DIR     = obj/

# Modüler Dosya Listeleme (Bu şekilde yönetmek çok daha kolaydır)
CORE_SRCS     = core/main.c core/init.c core/signals.c
LEXER_SRCS    = lexer/tokenizer.c lexer/token_utils.c
PARSER_SRCS   = parser/parser.c parser/utils.c
EXEC_SRCS     = executor/executor.c executor/pipeline.c executor/child.c \
                executor/path_finder.c executor/redirections.c
BUILTIN_SRCS  = builtins/ft_echo.c builtins/ft_cd.c builtins/ft_pwd.c \
                builtins/ft_export.c builtins/ft_unset.c builtins/ft_env.c \
                builtins/ft_exit.c
UTILS_SRCS    = utils/gc/gc.c utils/env/env_init.c utils/env/env_utils.c

# Tüm kaynak dosyalarının birleşimi
SRCS          = $(CORE_SRCS) $(LEXER_SRCS) $(PARSER_SRCS) \
                $(EXEC_SRCS) $(BUILTIN_SRCS) $(UTILS_SRCS)

# src/ klasörünü başa ekle
SRC           = $(addprefix $(SRC_DIR), $(SRCS))

# Obje dosyalarını src/ yerine obj/ klasörüne yönlendir
OBJ           = $(SRCS:%.c=$(OBJ_DIR)%.o)

# Renkler (Savunmada şık durur)
GREEN = \033[0;32m
RESET = \033[0m

all: $(LIBFT) $(NAME)

$(LIBFT):
	@make -C lib

$(NAME): $(OBJ)
	@$(CC) $(CFLAGS) $(OBJ) $(LIBS) -o $(NAME)
	@echo "$(GREEN)Minishell ready!$(RESET)"

# Obje dosyalarını derleme ve klasör oluşturma kuralı
$(OBJ_DIR)%.o: $(SRC_DIR)%.c
	@mkdir -p $(dir $@)
	@$(CC) $(CFLAGS) -c $< -o $@

clean:
	@make -C lib clean
	@rm -rf $(OBJ_DIR)
	@echo "Objects cleaned."

fclean: clean
	@make -C lib fclean
	@rm -f $(NAME)
	@echo "Everything cleaned."

re: fclean all

.PHONY: all clean fclean re